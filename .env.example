# Host ports
FRONTEND_PORT=3000
BACKEND_PORT=8080
FRONTEND_PUBLIC_URL=http://localhost:3000
FRONTEND_PUBLIC_URL_ALT=http://127.0.0.1:3000

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production

# Database
# For a MySQL server running on your host machine, host.docker.internal works on Docker Desktop.
# In production, replace this with your managed/private MySQL host.
BACKEND_CONNECTION_STRING=server=host.docker.internal;port=3306;database=pickandbookdb;user=root;password=change_me;Pooling=true;MinimumPoolSize=0;MaximumPoolSize=100;ConnectionTimeout=30;

# JWT
JWT_SECRET=replace_with_a_random_32_plus_character_secret
JWT_ISSUER=PickNBookApi
JWT_AUDIENCE=PickNBookUsers
JWT_EXPIRY_MINUTES=60

# Frontend build-time API config
# "/" keeps browser API calls same-origin; Nginx proxies /api to the backend service.
REACT_APP_API_BASE_URL=/
REACT_APP_AUTH_API_BASE_URL=/
REACT_APP_BUS_API_BASE_URL=/
REACT_APP_ADMIN_API_BASE_URL=/
REACT_APP_DASHBOARD_API_BASE_URL=/
REACT_APP_BANK_API_BASE_URL=/
REACT_APP_NOTIFICATIONS_API_BASE_URL=/
REACT_APP_PLACES_API_URL=/api/Places
REACT_APP_USE_DIRECT_API_IN_DEV=false
REACT_APP_DEFAULT_USER_ID=user_123

# Amadeus
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# SMTP email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_NAME=PickNBook
SMTP_SENDER_EMAIL=
SMTP_USERNAME=
SMTP_PASSWORD=

# WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Notifications
TICKET_EMAIL_URL=
