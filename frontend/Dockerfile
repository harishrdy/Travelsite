FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

ARG REACT_APP_API_BASE_URL=/
ARG REACT_APP_AUTH_API_BASE_URL=/
ARG REACT_APP_BUS_API_BASE_URL=/
ARG REACT_APP_ADMIN_API_BASE_URL=/
ARG REACT_APP_DASHBOARD_API_BASE_URL=/
ARG REACT_APP_BANK_API_BASE_URL=/
ARG REACT_APP_NOTIFICATIONS_API_BASE_URL=/
ARG REACT_APP_PLACES_API_URL=/api/Places
ARG REACT_APP_USE_DIRECT_API_IN_DEV=false
ARG REACT_APP_DEFAULT_USER_ID=user_123

ENV REACT_APP_API_BASE_URL=$REACT_APP_API_BASE_URL \
    REACT_APP_AUTH_API_BASE_URL=$REACT_APP_AUTH_API_BASE_URL \
    REACT_APP_BUS_API_BASE_URL=$REACT_APP_BUS_API_BASE_URL \
    REACT_APP_ADMIN_API_BASE_URL=$REACT_APP_ADMIN_API_BASE_URL \
    REACT_APP_DASHBOARD_API_BASE_URL=$REACT_APP_DASHBOARD_API_BASE_URL \
    REACT_APP_BANK_API_BASE_URL=$REACT_APP_BANK_API_BASE_URL \
    REACT_APP_NOTIFICATIONS_API_BASE_URL=$REACT_APP_NOTIFICATIONS_API_BASE_URL \
    REACT_APP_PLACES_API_URL=$REACT_APP_PLACES_API_URL \
    REACT_APP_USE_DIRECT_API_IN_DEV=$REACT_APP_USE_DIRECT_API_IN_DEV \
    REACT_APP_DEFAULT_USER_ID=$REACT_APP_DEFAULT_USER_ID \
    GENERATE_SOURCEMAP=false

COPY . .
RUN npm run build

FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
